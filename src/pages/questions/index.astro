---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TopBar from "../../components/TopBar.astro";
import QuestionCard from "../../components/QuestionCard.astro";
import FilterSidebar from "../../components/FilterSidebar.astro";
import Pagination from "../../components/Pagination.astro";
import AnswerPreferenceDialog from "../../components/AnswerPreferenceDialog.astro";
import ImageLightbox from "../../components/ImageLightbox.astro";
import { getSummary, questions } from "../../lib/questions";

const summary = getSummary();
---
<BaseLayout title="题目列表｜医学题库" description="浏览、筛选和分页查看第五篇习题集题目。">
  <TopBar />
  <main class="two-column">
    <FilterSidebar subjects={summary.subjects} chapters={summary.chapters} types={summary.types} tags={summary.tags} />
    <section class="question-list-shell">
      <div class="list-header">
        <div>
          <p class="eyebrow">题目列表</p>
          <h1>第五篇习题集</h1>
        </div>
        <p data-result-count>{summary.total} 道题</p>
      </div>
      <Pagination />
      <div class="question-list" data-question-list>
        {questions.map((question, index) => <QuestionCard question={question} index={index + 1} compact />)}
      </div>
      <Pagination />
    </section>
  </main>
  <AnswerPreferenceDialog />
  <ImageLightbox />
</BaseLayout>
